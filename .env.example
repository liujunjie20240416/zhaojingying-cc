DJANGO_SECRET_KEY="django-insecure-your-secret-key-here"

# GLM: used by preprocessing, memory reflection, RAG helpers and AI chat.
GLM_API_KEY=""
GLM_API_BASE="https://open.bigmodel.cn/api/paas/v4"
GLM_MODEL="glm-5.2"

# Vision chat: defaults to the GLM key/base when key/base are omitted.
VISION_LLM_API_KEY=""
VISION_LLM_API_BASE="https://open.bigmodel.cn/api/paas/v4"
VISION_LLM_MODEL="glm-5v-turbo"

# LangSmith: set these to inspect the full LLM data path.
LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
LANGSMITH_PROJECT="zhaojingying-cc"

# DashScope: used by text embeddings, ASR and TTS.
DASHSCOPE_API_KEY=""
DASHSCOPE_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"
DASHSCOPE_WSS_URL="wss://dashscope.aliyuncs.com/api-ws/v1/inference"
DASHSCOPE_VOICE_URL="https://dashscope.aliyuncs.com/api/v1/services/audio/tts/customization"

# Legacy fallback names for DashScope only.
# API_KEY=""
# API_BASE=""
# WSS_URL=""
# VOICE_URL=""
